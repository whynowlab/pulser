{
  "name": "pulser-cli",
  "version": "0.4.0",
  "description": "Diagnose, test, and fix Claude Code skills — without leaving the conversation.",
  "type": "module",
  "bin": {
    "pulser": "./dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "skill/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "claude-code",
    "skills",
    "lint",
    "cli",
    "anthropic"
  ],
  "author": "whynowlab",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
